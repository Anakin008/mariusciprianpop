# ============================================================
# Marius Ciprian Pop — variabile de mediu pentru formularul de contact
# Ruta A: Google Service Account + Sheets API direct.
# Copiaza acest fisier in `.env` si completeaza valorile reale.
# NU urca niciodata `.env` pe Git (e in .gitignore).
# Pe Vercel (production/preview/dev), aceleasi variabile sunt sincronizate
# via `vercel env add` — vezi SETUP.md.
# ============================================================

# JSON-ul complet al Service Account-ului, pe O SINGURA LINIE, intre ghilimele simple.
# Exemplu: GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n","client_email":"...@....iam.gserviceaccount.com",...}'
GOOGLE_SERVICE_ACCOUNT_JSON=

# ID-ul Google Sheet-ului (44 caractere). Il extragi din URL:
# https://docs.google.com/spreadsheets/d/{ACEST_ID}/edit
# Important: sheet-ul trebuie sa fie share-uit cu service account-ul ca Editor.
GOOGLE_SHEET_ID=

# API key de la Resend (https://resend.com/api-keys), incepe cu re_
RESEND_API_KEY=

# Destinatar principal (TO) al emailului de notificare (1 adresa)
EMAIL_TO=

# Destinatari BCC (ascunsi unul de altul si de TO). Comma-separated.
# Exemplu: sanakin227@gmail.com,marketing@example.com,sales@example.com
EMAIL_TO_BCC=

# Adresa FROM pentru email. Fara domeniu verificat, foloseste onboarding@resend.dev (limitat la teste).
# Cu domeniu verificat in Resend, pui: "Marius Ciprian Pop <contact@mariusciprianpop.ro>"
FROM_EMAIL=Marius Ciprian Pop <onboarding@resend.dev>
