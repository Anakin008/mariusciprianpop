# ============================================================
# Marius Ciprian Pop — variabile de mediu pentru formularul de contact
# Copiază acest fișier în `.env` și completează valorile reale.
# NU urca niciodată `.env` pe Git. Îl are .gitignore.
# Pe Vercel (production/preview), adaugă aceleași variabile în:
#   Vercel Dashboard → Project "mariusciprianpop" → Settings → Environment Variables
# ============================================================

# URL-ul web app-ului Google Apps Script (vezi SETUP.md pașii 1-4)
# Exemplu: https://script.google.com/macros/s/AKfycbxxxxxxxxxxxxxxxxxxxxxx/exec
GOOGLE_SHEET_WEBHOOK_URL=

# API key de la Resend (https://resend.com/api-keys). Începe cu re_
RESEND_API_KEY=

# Lista de emailuri care primesc notificarea (separați prin virgulă, fără spații în jur)
# Exemplu: marius@example.com,manager@example.com
NOTIFICATION_RECIPIENTS=

# Adresa FROM pentru email. Dacă nu ai domeniu verificat în Resend,
# folosește formatul de mai jos cu onboarding@resend.dev (e limitat la teste).
# După ce verifici un domeniu în Resend, schimbă cu: "Marius Ciprian Pop <contact@mariusciprianpop.ro>"
FROM_EMAIL=Marius Ciprian Pop <onboarding@resend.dev>
